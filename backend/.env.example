# Telemetry Bridge Service Configuration

# Ingestion Mode
# Options: "serial" (read from ESP32) or "simulator" (mock data)
INGESTION_MODE=simulator

# Serial Configuration (for serial mode)
# Linux: /dev/ttyUSB0, /dev/ttyACM0
# Windows: COM3, COM4, COM6
# macOS: /dev/cu.usbserial-*
SERIAL_PORT=COM6
SERIAL_BAUD_RATE=115200

# OpenAI Configuration (optional — for AI insight endpoint)
# Get your key from: https://platform.openai.com/api-keys
# If not set, the AI endpoint returns rule-based fallback recommendations
OPENAI_API_KEY=sk-your-key-here
